        pct_str = f"{pct:+.2f}%"
    else:
        value, day_gain, pct_str = 0, 0, "N/A"

    sign = "+" if day_gain >= 0 else ""
    us_rows_mob.append(f"<tr><td>{symbol}</td><td>{shares}</td><td>{avg_cost:.2f}</td><td>{price if price else 'N/A'}</td><td>{pct_str}</td></tr>")
