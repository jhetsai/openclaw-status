</body>
</html>"""

with open(OUT_HTML, "w") as f:
    f.write(HTML)
print(f"OK: {len(HTML)} bytes")
print(f"當日: {day_sign}{tw_day_gain:,.0f} | 累計: {gain_sign}{total_gain:,.0f}")
print(f"配息已入帳: {div_confirmed:,.0f} | 待發放: {div_pending:,.0f}")

# ===== R2 Upload =====
import boto3, os
try:
    with open(os.path.expanduser("~/.api_keys")) as f:
        for line in f:
            if line.strip() and not line.startswith("#") and "=" in line:
                k, v = line.strip().split("=", 1)
                os.environ[k.strip()] = v.strip()
except:
    pass
try:
    client = boto3.client('s3', endpoint_url='https://83de8038b42470b0576833e6d30e926d.r2.cloudflarestorage.com',
        aws_access_key_id=os.environ.get('R2_ACCESS_KEY', ''),
        aws_secret_access_key=os.environ.get('R2_SECRET_KEY', ''))
    client.upload_file(OUT_HTML, 'shared-files', 'stock/index.html')
    print("R2 OK")
except Exception as e:
    print(f"R2 FAIL: {e}")