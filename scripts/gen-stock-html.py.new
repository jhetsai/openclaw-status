for s in tw_stocks:
    code = s["symbol"]
    name = s.get("name", code)
    shares = s.get("shares", 0)
    cost_sum = s.get("total_cost", 0)
    avg_cost = s.get("cost", 0)
    tw_total_cost += cost_sum

    url = f"https://tw.stock.yahoo.com/quote/{code}.TW"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            html = resp.read().decode("utf-8", errors="ignore")
        price_match = re.search(r'"regularMarketPrice"\s*:\s*([\d.]+)', html)
        change_match = re.search(r'"regularMarketChange"\s*:\s*([-\d.]+)', html)
        pct_match = re.search(r'"regularMarketChangePercent"\s*:\s*([-\d.]+)', html)
        price = float(price_match.group(1)) if price_match else None
        change = float(change_match.group(1)) if change_match else 0
        pct = float(pct_match.group(1)) if pct_match else 0
    except Exception as e:
        price, change, pct = None, 0, 0

    if price:
        value = price * shares
        tw_total_value += value
        day_gain = change * shares
    else:
        value, day_gain = 0, 0

    pct_str = f"{pct:+.2f}%" if price else "N/A"
    sign = "+" if change >= 0 else ""
    tw_rows_mob.append(f"<tr><td>{code}</td><td>{name}</td><td>{shares}</td><td>{avg_cost:.2f}</td><td>{price if price else 'N/A'}</td><td class='{'up' if change>=0 else 'dn'}'>{sign}{change:.2f}</td><td>{pct_str}</td></tr>")
    tw_rows_desk.append(f"<tr><td>{code}</td><td>{name}</td><td>{shares}</td><td>{avg_cost:.2f}</td><td>{price if price else 'N/A'}</td><td>{value:,.0f}</td><td class='{'up' if day_gain>=0 else 'dn'}'>{sign}{day_gain:,.0f}</td><td>{pct_str}</td></tr>")

# ===== Build ref futures =====
ref_map = [
    ("TXF", "TXF00", " 台股期指", ""),
    ("TXFR1", "TXFR1", " 遠月", ""),
    ("TEFR1", "TEFR1", " 電金", ""),
]
ref_mob_template = "<tr><td>{sym}</td><td>{price}</td><td>{pct}</td></tr>"
ref_desk_template = "<tr><td>{sym}</td><td>{name}</td><td>{price}</td><td>{pct}</td></tr>"

import urllib.request as req
for sym, yh_sym, name, _ in ref_map:
    try:
        url = f"https://tw.stock.yahoo.com/quote/{yh_sym}.TW"
        request = req.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with req.urlopen(request, timeout=5) as resp:
            html = resp.read().decode("utf-8", errors="ignore")
        price_match = re.search(r'"regularMarketPrice"\s*:\s*([\d.]+)', html)
        change_match = re.search(r'"regularMarketChange"\s*:\s*([-\d.]+)', html)
        pct_match = re.search(r'"regularMarketChangePercent"\s*:\s*([-\d.]+)', html)
        price = float(price_match.group(1)) if price_match else 0
        change = float(change_match.group(1)) if change_match else 0
        pct = float(pct_match.group(1)) if pct_match else 0
        pct_str = f"{pct:+.2f}%"
        sign = "+" if change >= 0 else ""
        ref_mob.append(ref_mob_template.format(sym=sym, price=f"{sign}{change:.0f}", pct=pct_str))
        ref_desk.append(ref_desk_template.format(sym=sym, name=name, price=f"{price:.0f}", pct=pct_str))
        ref_codes.add(yh_sym)
    except Exception as e:
        ref_mob.append(ref_mob_template.format(sym=sym, price="N/A", pct=""))
        ref_desk.append(ref_desk_template.format(sym=sym, name=name, price="N/A", pct=""))

# ===== Build US stock table =====
us_rows_mob, us_rows_desk = [], []
