# Load upcoming ex-dividend dates
upcoming_div = []
if os.path.exists(TWSE_DATA_FILE):
    with open(TWSE_DATA_FILE) as f:
        twse_data = json.load(f)
    from datetime import datetime
    today_roc = f"{datetime.now().year-1911:03d}{datetime.now().month:02d}{datetime.now().day:02d}"
    upcoming_div = [
        d for d in twse_data.get("upcoming_div", [])
        if d.get("Date", "") >= today_roc
    ]
    if upcoming_div:
        # Load manual dividend overrides
        manual_div_file = os.path.join(WORKSPACE, "taiwan_stock/manual_dividend.json")
        manual_div = {}
        if os.path.exists(manual_div_file):
            with open(manual_div_file) as f:
                manual_div = json.load(f)
        div_rows = ""
        for d in upcoming_div[:10]:
            date_tw = d.get("Date", "")
            year = int(date_tw[:3]) + 1911
            month_day = date_tw[3:5] + "/" + date_tw[5:]
            date_str = f"{year}/{month_day}"
            code = d.get("Code", "")
            cash = d.get("CashDividend", "") or ""
            if (cash == "-" or cash == "") and code in manual_div:
                cash = str(manual_div[code]["cash"])
            if not cash or cash == "-":
                cash = "-"
            name = d.get("Name", "")
            # Fetch payout date from Yahoo
            payout_str = "-"
            url = f"https://tw.stock.yahoo.com/quote/{code}.TW/dividend"
            try:
                result = subprocess.run(
                    ['curl', '-s', '--max-time', '8', '-H', 'User-Agent: Mozilla/5.0', url],
                    capture_output=True, text=True, timeout=10
                )
                if result.returncode == 0:
                    html = result.stdout
                    # Extract all cells from Yahoo dividend table
                    cells = re.findall(r'<div class="Fxg\(1\).*?">(?:<span>)?([^<]+)(?:</span>)?(?:</div>)', html)
                    # Convert ROC exdiv date to AD for matching
                    roc_year = int(date_tw[:3])
                    ad_year = roc_year + 1911
                    month = date_tw[3:5]
                    day = date_tw[5:]
                    date_tw_ad = f"{ad_year}/{month}/{day}"
                    # Each entry spans 10 cells: period, cash_div, stock, yield%, close, exdiv, exright, payout, stock_payout, filldays
                    n = 10

                    for i in range(0, len(cells)-n+1, n):
                        period = cells[i+3].strip()
                        c_div = cells[i+4].strip()
                        exdiv = cells[i+8].strip()
                        pyd = cells[i+10].strip()
                        if period in ('所屬期間', '現金股利', '股票股利', '現金殖利率', '', None) or not period:
                            continue
                        if exdiv == date_tw_ad and c_div not in ('-', '', None):
                            payout_str = pyd
                            if cash == "-" or cash == "":
                                cash = c_div
                            break
            except:
                pass
            div_rows += f"<tr><td>{code}</td><td>{name}</td><td>{date_str}</td><td>{payout_str}</td><td>{cash}</td></tr>\n"
        upcoming_div_html = f"""<div class="card collapsed">
<h3 class="section-title" onclick="this.parentElement.classList.toggle('collapsed')">📅 近期除息預告</h3>
<table>
<tr><th>代碼</th><th>名稱</th><th>除息日</th><th>發放日</th><th>現金股利</th></tr>
{div_rows}</table>
</div>"""
    else:
        upcoming_div_html = ""
else:
    upcoming_div_html = ""

YAHOO_HOSTS = ['query1.finance.yahoo.com', 'query2.finance.yahoo.com']

def fetch_prev_close(symbol):
    for host in YAHOO_HOSTS:
        try:
            url = f"https://{host}/v8/finance/chart/{symbol}?interval=1d&range=2d"
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=5) as resp:
                data = json.loads(resp.read())
            result = data.get("chart", {}).get("result", [])
            if result:
                meta = result[0].get("meta", {})
                prev_close = meta.get("previous_close")
                currency = meta.get("currency", "USD")
                return prev_close, currency
        except:
            continue
    return None, None

def fetch_us_price(symbol):
    price, currency = fetch_prev_close(symbol)
    return price, currency

def get_fx_rate():
    try:
        url = "https://query1.finance.yahoo.com/v8/finance/chart/USDTWD=X?interval=1d&range=2d"
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
        result = data.get("chart", {}).get("result", [])
        if result:
            meta = result[0].get("meta", {})
            return meta.get("regular_market_price", 31.5)
    except:
        return 31.5

fx = get_fx_rate()

# ===== Build tw stock table =====
tw_rows_mob, tw_rows_desk = [], []
ref_mob, ref_desk = [], []
